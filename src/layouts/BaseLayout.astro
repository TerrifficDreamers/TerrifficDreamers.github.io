---
// Self-hosted Fonts (DSGVO-konform, kein Google-Fonts-CDN)
import '@fontsource-variable/inter/index.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/400-italic.css';

import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/components.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ComingSoonGate from '../components/ComingSoonGate.astro';
import site from '../config/site.json';
import { ViewTransitions } from 'astro:transitions';

const { title, description = site.tagline, noindex = false } = Astro.props;
const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#0E0B0C" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="/media/logo/club-logo.png" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="icon" type="image/png" href="/media/logo/club-logo.png" />
  {Astro.site && <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />}
  <ViewTransitions />
</head>
<body>
  <ComingSoonGate />
  <a href="#main" class="skip-link">Zum Inhalt springen</a>
  <Navbar />
  <main id="main">
    <slot />
  </main>
  <Footer />

  <script>
    import '../scripts/mobileNav.js';
    import '../scripts/reveal.js';
    import '../scripts/navScroll.js';
  </script>
</body>
</html>
