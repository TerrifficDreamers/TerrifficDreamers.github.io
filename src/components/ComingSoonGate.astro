---
import site from '../config/site.json';
const cs = site.comingSoon;
if (!cs?.enabled) return null;
---
<!-- Inline-Script: setzt Lock-Klasse VOR dem ersten Paint -->
<script is:inline define:vars={{ unlockKey: 'td-unlocked' }}>
  try {
    if (sessionStorage.getItem(unlockKey) !== '1') {
      document.documentElement.classList.add('is-locked');
    }
  } catch (_) {
    document.documentElement.classList.add('is-locked');
  }
</script>

<style is:global>
  html.is-locked body > *:not(.coming-soon) { display: none !important; }
  html.is-locked, html.is-locked body { overflow: hidden; }
</style>

<div class="coming-soon" role="dialog" aria-modal="true" aria-labelledby="cs-title">
  <div class="coming-soon__bg">
    <video autoplay muted loop playsinline poster="/media/hero/poster.jpg" aria-hidden="true">
      <source src="/media/hero/background.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="coming-soon__overlay"></div>

  <div class="coming-soon__inner">
    <img src="/media/logo/club-logo.png" alt={site.name} width="140" height="140" class="coming-soon__logo" />
    <h1 id="cs-title" class="coming-soon__title">{cs.title}</h1>
    <p class="coming-soon__message">{cs.message}</p>

    <form class="coming-soon__form" data-cs-form autocomplete="off">
      <label for="cs-pw" class="visually-hidden">Passwort</label>
      <input
        id="cs-pw"
        name="password"
        type="password"
        placeholder="Passwort"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        required
      />
      <button type="submit" class="btn btn--primary">Entsperren</button>
      <p class="coming-soon__error" data-cs-error hidden>Falsches Passwort.</p>
    </form>
  </div>
</div>

<style>
  .coming-soon {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    isolation: isolate;
    color: var(--color-text);
    background: var(--color-bg);
  }
  .coming-soon__bg { position: absolute; inset: 0; z-index: -2; }
  .coming-soon__bg video { width: 100%; height: 100%; object-fit: cover; }
  .coming-soon__overlay {
    position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(180deg, rgba(14,11,12,0.65), rgba(14,11,12,0.85));
  }
  .coming-soon__inner {
    width: min(520px, 92vw);
    padding: var(--sp-8) var(--sp-6);
    background: rgba(26, 18, 19, 0.7);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: var(--shadow-md);
  }
  .coming-soon__logo {
    border-radius: 50%;
    box-shadow: 0 0 0 2px var(--color-brass), 0 8px 24px rgba(0,0,0,0.5);
    margin-bottom: var(--sp-6);
  }
  .coming-soon__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3rem);
    margin: 0 0 var(--sp-3);
    letter-spacing: 0.02em;
  }
  .coming-soon__message {
    color: var(--color-muted);
    margin-bottom: var(--sp-6);
    font-size: 0.95rem;
  }
  .coming-soon__form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: stretch;
  }
  .coming-soon__form input {
    width: 100%;
    padding: 0.85rem 1rem;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    font-family: inherit;
    font-size: 1rem;
    text-align: center;
    letter-spacing: 0.06em;
    min-height: 44px;
  }
  .coming-soon__form input:focus {
    outline: none;
    border-color: var(--color-brass);
    box-shadow: 0 0 0 3px rgba(176, 141, 87, 0.2);
  }
  .coming-soon__form .btn { justify-content: center; }
  .coming-soon__error {
    color: #ff8a8a;
    margin: 0;
    font-size: 0.85rem;
  }
  .coming-soon.shake .coming-soon__inner {
    animation: shake 380ms cubic-bezier(.36,.07,.19,.97) both;
  }
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  @keyframes shake {
    10%, 90% { transform: translate3d(-2px, 0, 0); }
    20%, 80% { transform: translate3d(4px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-6px, 0, 0); }
    40%, 60% { transform: translate3d(6px, 0, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .coming-soon.shake .coming-soon__inner { animation: none; }
  }
</style>

<script is:inline define:vars={{ expected: cs.passwordHash, unlockKey: 'td-unlocked' }}>
  (() => {
    const form = document.querySelector('[data-cs-form]');
    const errorEl = document.querySelector('[data-cs-error]');
    const gate = document.querySelector('.coming-soon');
    if (!form || !gate) return;

    async function sha256(text) {
      const buf = new TextEncoder().encode(text);
      const hash = await crypto.subtle.digest('SHA-256', buf);
      return Array.from(new Uint8Array(hash))
        .map(b => b.toString(16).padStart(2, '0'))
        .join('');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name="password"]');
      const value = (input?.value || '').trim();
      const hash = await sha256(value);

      if (hash === expected) {
        try { sessionStorage.setItem(unlockKey, '1'); } catch (_) {}
        document.documentElement.classList.remove('is-locked');
        gate.remove();
      } else {
        errorEl.hidden = false;
        gate.classList.remove('shake');
        // re-trigger animation
        void gate.offsetWidth;
        gate.classList.add('shake');
        input.value = '';
        input.focus();
      }
    });
  })();
</script>
