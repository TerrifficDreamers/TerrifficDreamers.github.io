---
import site from '../config/site.json';
const cs = site.comingSoon;
if (!cs?.enabled) return null;
---
<!-- Inline-Script: setzt Lock-Klasse VOR dem ersten Paint -->
<script is:inline define:vars={{ unlockKey: 'td-unlocked' }}>
  try {
    if (localStorage.getItem(unlockKey) !== '1') {
      document.documentElement.classList.add('is-locked');
    }
  } catch (_) {
    document.documentElement.classList.add('is-locked');
  }
</script>

<style is:global>
  /* Gate nur sichtbar wenn gelockt — !important wegen Scoped-CSS-Spezifität */
  html:not(.is-locked) .coming-soon { display: none !important; }
  html.is-locked body > *:not(.coming-soon) { display: none !important; }
  html.is-locked, html.is-locked body { overflow: hidden; }
</style>

<div class="coming-soon" role="dialog" aria-modal="true" aria-labelledby="cs-title">
  <div class="coming-soon__bg">
    <video autoplay muted loop playsinline poster="/media/hero/poster.jpg" aria-hidden="true">
      <source src="/media/hero/background.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="coming-soon__overlay"></div>
  <div class="coming-soon__vignette" aria-hidden="true"></div>

  <div class="coming-soon__inner">
    <div class="coming-soon__logo-wrap">
      <span class="coming-soon__logo-ring" aria-hidden="true"></span>
      <img src="/media/logo/club-logo.png" alt={site.name} width="160" height="160" class="coming-soon__logo" />
    </div>

    <h1 id="cs-title" class="coming-soon__title">
      {cs.title.split('').map((ch, i) => (
        <span class="coming-soon__char" style={`--i:${i}`}>{ch === ' ' ? ' ' : ch}</span>
      ))}
    </h1>

    <div class="coming-soon__rule" aria-hidden="true"></div>
    <p class="coming-soon__message">{cs.message}</p>

    <form class="coming-soon__form" data-cs-form autocomplete="off">
      <label for="cs-pw" class="visually-hidden">Passwort</label>
      <div class="coming-soon__input-wrap">
        <input
          id="cs-pw"
          name="password"
          type="password"
          placeholder="Passwort"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          required
        />
      </div>
      <button type="submit" class="btn btn--primary coming-soon__submit">
        <span>Entsperren</span>
      </button>
      <p class="coming-soon__error" data-cs-error hidden>Falsches Passwort.</p>
    </form>
  </div>
</div>

<style>
  .coming-soon {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    isolation: isolate;
    color: var(--color-text);
    background: var(--color-bg);
    animation: cs-fade-in 1100ms var(--ease) both;
  }
  .coming-soon.cs-leaving {
    animation: cs-fade-out 700ms var(--ease) both;
  }

  /* Hintergrund */
  .coming-soon__bg { position: absolute; inset: 0; z-index: -3; }
  .coming-soon__bg video {
    width: 100%; height: 100%; object-fit: cover;
    animation: cs-bg-zoom 18s ease-in-out infinite alternate;
  }
  .coming-soon__overlay {
    position: absolute; inset: 0; z-index: -2;
    background:
      radial-gradient(ellipse at 50% 35%, rgba(123,31,43,0.25) 0%, transparent 60%),
      linear-gradient(180deg, rgba(14,11,12,0.55) 0%, rgba(14,11,12,0.85) 100%);
  }
  .coming-soon__vignette {
    position: absolute; inset: 0; z-index: -1;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(14,11,12,0.85) 100%);
    pointer-events: none;
  }

  /* Card */
  .coming-soon__inner {
    width: min(540px, 92vw);
    padding: var(--sp-12) var(--sp-8) var(--sp-8);
    background: linear-gradient(180deg, rgba(34, 23, 25, 0.78) 0%, rgba(20, 14, 15, 0.82) 100%);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    box-shadow:
      0 0 0 1px rgba(176, 141, 87, 0.08) inset,
      0 24px 60px rgba(0, 0, 0, 0.55),
      0 8px 28px rgba(123, 31, 43, 0.18);
    animation: cs-card-in 900ms var(--ease) 100ms both;
  }
  @media (max-width: 480px) {
    .coming-soon__inner { padding: var(--sp-8) var(--sp-6) var(--sp-6); }
  }

  /* Logo mit pulsing Ring */
  .coming-soon__logo-wrap {
    position: relative;
    width: 160px; height: 160px;
    margin: 0 auto var(--sp-6);
    animation: cs-pop-in 800ms var(--ease) 250ms both;
  }
  .coming-soon__logo {
    position: relative; z-index: 1;
    width: 160px; height: 160px;
    border-radius: 50%;
    box-shadow:
      0 0 0 2px var(--color-brass),
      0 12px 40px rgba(0,0,0,0.55),
      0 0 50px rgba(176, 141, 87, 0.18);
  }
  .coming-soon__logo-ring {
    position: absolute; inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(176, 141, 87, 0.5);
    animation: cs-ring-pulse 3.6s ease-in-out infinite;
  }
  .coming-soon__logo-ring::after {
    content: "";
    position: absolute; inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(176, 141, 87, 0.25);
    animation: cs-ring-pulse 3.6s ease-in-out infinite 1.2s;
  }

  /* Title — pro Buchstabe einfaden */
  .coming-soon__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 7vw, 3.4rem);
    font-weight: 500;
    margin: 0 0 var(--sp-3);
    letter-spacing: 0.04em;
    line-height: 1.1;
  }
  .coming-soon__char {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.6em);
    animation: cs-char 600ms var(--ease) forwards;
    animation-delay: calc(450ms + var(--i) * 35ms);
  }

  /* Goldene Trennlinie */
  .coming-soon__rule {
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-brass), transparent);
    margin: var(--sp-4) auto var(--sp-6);
    animation: cs-rule 900ms var(--ease) 1100ms forwards;
  }

  .coming-soon__message {
    color: var(--color-muted);
    margin-bottom: var(--sp-8);
    font-size: 0.98rem;
    line-height: 1.6;
    opacity: 0;
    animation: cs-fade-up 700ms var(--ease) 1300ms forwards;
  }

  /* Form */
  .coming-soon__form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: stretch;
    opacity: 0;
    animation: cs-fade-up 700ms var(--ease) 1500ms forwards;
  }
  .coming-soon__input-wrap {
    position: relative;
  }
  .coming-soon__form input {
    width: 100%;
    padding: 1rem 1.2rem;
    background: rgba(14, 11, 12, 0.55);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-family: inherit;
    font-size: 1rem;
    text-align: center;
    letter-spacing: 0.1em;
    min-height: 48px;
    transition: border-color 200ms var(--ease), box-shadow 200ms var(--ease), background 200ms var(--ease);
  }
  .coming-soon__form input::placeholder {
    color: rgba(154, 142, 131, 0.6);
    letter-spacing: 0.06em;
  }
  .coming-soon__form input:focus {
    outline: none;
    border-color: var(--color-brass);
    background: rgba(14, 11, 12, 0.75);
    box-shadow: 0 0 0 4px rgba(176, 141, 87, 0.15), 0 8px 24px rgba(0,0,0,0.3);
  }

  /* Button mit Shimmer */
  .coming-soon__submit {
    position: relative;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-wine) 0%, var(--color-wine-bright) 100%);
    transition: transform 200ms var(--ease), box-shadow 250ms var(--ease);
  }
  .coming-soon__submit::before {
    content: "";
    position: absolute;
    top: 0; left: -120%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(237, 230, 220, 0.18), transparent);
    transform: skewX(-20deg);
    transition: left 800ms var(--ease);
    pointer-events: none;
  }
  .coming-soon__submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(123, 31, 43, 0.45), 0 0 0 1px var(--color-brass);
  }
  .coming-soon__submit:hover::before { left: 130%; }
  .coming-soon__submit:active { transform: translateY(0); }
  .coming-soon__submit > span { position: relative; z-index: 1; }

  .coming-soon__error {
    color: #ff8a8a;
    margin: 0;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
  }

  .coming-soon.shake .coming-soon__inner {
    animation: cs-shake 420ms cubic-bezier(.36,.07,.19,.97) both;
  }

  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  /* Animations */
  @keyframes cs-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes cs-fade-out {
    from { opacity: 1; transform: scale(1); filter: blur(0); }
    to   { opacity: 0; transform: scale(1.04); filter: blur(8px); }
  }
  @keyframes cs-card-in {
    from { opacity: 0; transform: translateY(24px) scale(0.98); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes cs-pop-in {
    0%   { opacity: 0; transform: scale(0.6); }
    60%  { transform: scale(1.06); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes cs-ring-pulse {
    0%   { transform: scale(1); opacity: 0.7; }
    70%  { transform: scale(1.18); opacity: 0; }
    100% { transform: scale(1.18); opacity: 0; }
  }
  @keyframes cs-char {
    to { opacity: 1; transform: none; }
  }
  @keyframes cs-rule {
    to { width: 80px; }
  }
  @keyframes cs-fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes cs-bg-zoom {
    from { transform: scale(1.04) translate3d(0,0,0); }
    to   { transform: scale(1.12) translate3d(-1%, -1.5%, 0); }
  }
  @keyframes cs-shake {
    10%, 90% { transform: translate3d(-2px, 0, 0); }
    20%, 80% { transform: translate3d(4px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-6px, 0, 0); }
    40%, 60% { transform: translate3d(6px, 0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .coming-soon, .coming-soon *,
    .coming-soon__bg video,
    .coming-soon__logo-ring,
    .coming-soon__logo-ring::after {
      animation: none !important;
    }
    .coming-soon__char { opacity: 1; transform: none; }
    .coming-soon__rule { width: 80px; }
    .coming-soon__message,
    .coming-soon__form { opacity: 1; }
  }
</style>

<script is:inline define:vars={{ expected: cs.passwordHash, unlockKey: 'td-unlocked' }}>
  (() => {
    const form = document.querySelector('[data-cs-form]');
    const errorEl = document.querySelector('[data-cs-error]');
    const gate = document.querySelector('.coming-soon');
    if (!form || !gate) return;

    async function sha256(text) {
      const buf = new TextEncoder().encode(text);
      const hash = await crypto.subtle.digest('SHA-256', buf);
      return Array.from(new Uint8Array(hash))
        .map(b => b.toString(16).padStart(2, '0'))
        .join('');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name="password"]');
      const value = (input?.value || '').trim();
      const hash = await sha256(value);

      if (hash === expected) {
        try { localStorage.setItem(unlockKey, '1'); } catch (_) {}
        gate.classList.add('cs-leaving');
        setTimeout(() => {
          document.documentElement.classList.remove('is-locked');
          gate.remove();
        }, 700);
      } else {
        errorEl.hidden = false;
        gate.classList.remove('shake');
        void gate.offsetWidth;
        gate.classList.add('shake');
        input.value = '';
        input.focus();
      }
    });
  })();
</script>
