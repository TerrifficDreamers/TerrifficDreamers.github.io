---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../config/site.json';

const requirements = [
  'Mindestalter 16 Jahre',
  'Spiellevel mindestens 20',
  'Discord und WhatsApp aktiv nutzen',
  'Regelmäßige Teilnahme an beiden Treffen pro Woche'
];
const steps = [
  { n: 1, title: 'Bewerbung absenden', text: 'Du füllst das Formular aus und schickst es ab.' },
  { n: 2, title: 'Bewertung', text: 'Sonntags um 15:00 Uhr werden alle eingegangenen Bewerbungen gemeinsam besprochen.' },
  { n: 3, title: 'Benachrichtigung', text: 'Bei Annahme bekommst du eine Rückmeldung mit den nächsten Schritten.' },
  { n: 4, title: 'Bewerbungsserver', text: 'Einladung auf den internen Discord-Bewerbungsserver.' },
  { n: 5, title: 'Kennenlern-Treffen', text: 'Treffen mit deinem Patenteam und der Clubleitung im Spiel.' }
];
---
<BaseLayout title="Bewerbung" description="So wirst du Teil der Terrific Dreamers.">
  <header class="page-header">
    <div class="container container--narrow">
      <span class="eyebrow">Mitglied werden</span>
      <h1>Bewerbungsverfahren</h1>
      <p class="muted">Lust, Teil der Terrific Dreamers zu werden? So läuft's.</p>
    </div>
  </header>

  <section>
    <div class="container container--narrow">
      <h2 data-reveal>Voraussetzungen</h2>
      <ul style="list-style:none; padding:0;">
        {requirements.map((r) => (
          <li class="card" style="padding: var(--sp-3) var(--sp-5); margin-bottom: var(--sp-3);" data-reveal>
            <span style="color: var(--color-brass); margin-right: var(--sp-3);">✓</span>{r}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section style="background: var(--color-surface);">
    <div class="container container--narrow">
      <h2 data-reveal>Ablauf</h2>
      <ol style="list-style:none; padding:0; counter-reset: step;">
        {steps.map((s) => (
          <li class="card" style="margin-bottom: var(--sp-4); display:grid; grid-template-columns:48px 1fr; gap:var(--sp-4); align-items:start;" data-reveal>
            <div class="rank__num" aria-hidden="true">{s.n}</div>
            <div>
              <h3 style="margin: 0 0 var(--sp-1); font-size: 1.2rem;">{s.title}</h3>
              <p class="muted" style="margin:0;">{s.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section>
    <div class="container container--narrow" style="text-align:center;">
      <h2 data-reveal>Bereit?</h2>
      <p class="muted" data-reveal>Das Bewerbungsformular läuft über Google Forms.</p>
      <p data-reveal>
        <a class="btn btn--primary" href={site.applicationFormUrl} target="_blank" rel="noopener noreferrer">
          Zur Bewerbung →
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
