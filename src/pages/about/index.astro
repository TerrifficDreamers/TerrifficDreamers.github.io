---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pages = [
  { href: '/about/stammplatz', title: 'Stammplatz', desc: 'Silverglade Landgut — wo wir uns ingame treffen.' },
  { href: '/about/cluboutfit', title: 'Cluboutfit', desc: 'Unser einheitlicher Look — für Reiter und Pferd.' },
  { href: '/about/rangsystem', title: 'Rangsystem', desc: 'Sechs Stufen, klare Aufgaben.' },
  { href: '/about/wochenplan', title: 'Wochenplan', desc: 'Wann wir uns sehen.' }
];
---
<BaseLayout title="About">
  <header class="page-header">
    <div class="container container--narrow">
      <span class="eyebrow">Über uns</span>
      <h1 data-letters>About us</h1>
      <p class="muted">Alles, was du über die Terrific Dreamers wissen solltest.</p>
    </div>
  </header>

  <section>
    <div class="container">
      <div class="grid" data-reveal-stagger>
        {pages.map((p) => (
          <a class="card card--link" href={p.href} data-reveal="fade-up">
            <h3 class="card__title">{p.title}</h3>
            <p class="muted">{p.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
