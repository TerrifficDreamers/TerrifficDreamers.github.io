---
import BaseLayout from '../../layouts/BaseLayout.astro';
import schedule from '../../config/schedule.json';
---
<BaseLayout title="Wochenplan" description="Wann wir uns treffen.">
  <header class="page-header">
    <div class="container container--narrow">
      <span class="eyebrow">About</span>
      <h1 data-letters>Wochenplan</h1>
      <p class="muted">Unsere regelmäßigen Treffen.</p>
    </div>
  </header>

  <section>
    <div class="container container--narrow text-center">
      <figure class="plain-figure plain-figure--sm" data-reveal>
        <img
          src="/media/misc/wochenplan.png"
          alt="Wochenplan: Montag 19:00, Dienstag 19:00, Freitag 20:00"
          loading="eager"
          onerror="this.style.opacity='0.25'; this.parentElement.querySelector('.plain-figure__missing').hidden = false;"
        />
        <figcaption class="plain-figure__missing muted" hidden>
          Bild fehlt noch — bitte ablegen unter <code>/media/misc/wochenplan.png</code>.
        </figcaption>
      </figure>

      <ol class="weekplan" data-reveal-stagger>
        {schedule.regular.map((s) => (
          <li class="weekplan__item" data-reveal="fade-left">
            <div class="weekplan__when">
              <span class="weekplan__day">{s.day}</span>
              <span class="weekplan__time">{s.time}<span class="weekplan__time-suffix"> Uhr</span></span>
            </div>
            <div class="weekplan__divider" aria-hidden="true"></div>
            <div class="weekplan__what">
              <p class="weekplan__note">{s.note}</p>
              <p class="weekplan__loc">{s.location}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="muted communication-note" data-reveal>{schedule.communication}</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* No-background image figure */
  .plain-figure {
    display: block;
    margin-left: auto;
    margin-right: auto;
    margin-top: 0;
    margin-bottom: var(--sp-14);
    text-align: center;
  }
  .plain-figure img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    background: transparent;
  }
  .plain-figure--sm { max-width: 300px; }
  @media (max-width: 560px) {
    .plain-figure--sm { max-width: 240px; }
  }
  .plain-figure__missing {
    margin-top: var(--sp-3);
    font-size: 0.85rem;
  }

  /* Weekplan list */
  .weekplan {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 640px;
    display: grid;
    gap: var(--sp-4);
    text-align: left;
  }
  .weekplan__item {
    position: relative;
    display: grid;
    grid-template-columns: 130px auto 1fr;
    align-items: center;
    gap: var(--sp-5);
    padding: var(--sp-4) var(--sp-6);
    background: linear-gradient(135deg, rgba(123, 31, 43, 0.06) 0%, var(--color-surface) 60%);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-wine);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: transform 320ms var(--ease), box-shadow 320ms var(--ease), border-color 320ms var(--ease);
  }
  .weekplan__item:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-brass) 45%, var(--color-border));
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.4);
  }

  .weekplan__when {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .weekplan__day {
    font-family: var(--font-display);
    font-size: 1.55rem;
    line-height: 1;
    color: var(--color-brass);
    letter-spacing: 0.02em;
  }
  .weekplan__time {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.04em;
  }
  .weekplan__time-suffix {
    font-weight: 400;
    color: var(--color-muted);
    margin-left: 2px;
  }

  .weekplan__divider {
    width: 1px;
    height: 42px;
    background: linear-gradient(180deg, transparent, var(--color-border), transparent);
  }

  .weekplan__what { min-width: 0; }
  .weekplan__note {
    margin: 0 0 4px;
    font-weight: 600;
    color: var(--color-text);
    font-size: 1rem;
  }
  .weekplan__loc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.92rem;
  }

  .communication-note {
    font-size: 0.92rem;
    margin-top: var(--sp-10);
  }

  @media (max-width: 560px) {
    .weekplan__item {
      grid-template-columns: 1fr;
      gap: var(--sp-2);
      text-align: center;
    }
    .weekplan__when { align-items: center; }
    .weekplan__divider {
      width: 80px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--color-border), transparent);
      margin: 4px auto;
    }
  }
</style>
