---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../config/site.json';
---
<BaseLayout title="Stammplatz">
  <header class="page-header">
    <div class="container container--narrow">
      <span class="eyebrow">About</span>
      <h1 data-letters>Unser Stammplatz</h1>
    </div>
  </header>

  <section>
    <div class="container container--narrow text-center">
      <p data-reveal>
        Wir treffen uns zu jedem Clubtreffen am <strong>Silverglade Landgut</strong> auf <strong>{site.server}</strong>.
        Hier startet jedes Treffen — von hier reiten wir gemeinsam los.
      </p>

      <figure class="plain-figure" data-reveal>
        <img
          src="/media/misc/stammplatz.png"
          alt="Silverglade Landgut — unser Stammplatz"
          loading="eager"
          onerror="this.style.opacity='0.25'; this.parentElement.querySelector('.plain-figure__missing').hidden = false;"
        />
        <figcaption class="plain-figure__caption muted">
          Silverglade Landgut — unser Treffpunkt
        </figcaption>
        <figcaption class="plain-figure__missing muted" hidden>
          Bild fehlt noch — bitte ablegen unter <code>/media/misc/stammplatz.png</code>.
        </figcaption>
      </figure>
    </div>
  </section>
</BaseLayout>

<style>
  .plain-figure {
    margin: var(--sp-8) auto 0;
    max-width: 520px;
  }
  .plain-figure img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    background: transparent;
  }
  .plain-figure__caption {
    margin-top: var(--sp-3);
    font-size: 0.9rem;
  }
  .plain-figure__missing { margin-top: var(--sp-3); font-size: 0.85rem; }
</style>
